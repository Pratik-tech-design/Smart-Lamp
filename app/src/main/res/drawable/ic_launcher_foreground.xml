    <path
        android:pathData="M54,0 L54,30"
        android:strokeColor="#FAF2E6"
        android:strokeWidth="1.8"
        android:strokeLineCap="round" />

    <!-- Wooden Socket Base (Dark rich wood with rounded corners) -->
