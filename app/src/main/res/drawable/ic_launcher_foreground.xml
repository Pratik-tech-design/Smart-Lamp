    <path
        android:pathData="M46,33 L46,45"
        android:strokeColor="#40FFFFFF"
        android:strokeWidth="1.2"
        android:strokeLineCap="round" />

    <!-- Socket Neck / Base Ring -->
    <path
        android:pathData="M48,48 L60,48 L60,50 C60,50.6 59.5,51 59,51 L49,51 C48.5,51 48,50.6 48,50 Z"
        android:fillColor="#9E9385" />

