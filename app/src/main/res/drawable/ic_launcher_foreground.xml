    <!-- Warm Ambient Ambient Light Halo -->
    <path android:pathData="M54,68m-28,0a28,28 0,1 1,56 0a28,28 0,1 1,-56 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="68"
                android:gradientRadius="28"
                android:type="radial">
                <item
                    android:color="#B0FFE580"
                    android:offset="0.0" />
                <item
                    android:color="#00FFE580"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

