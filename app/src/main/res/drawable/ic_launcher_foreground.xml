<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Soft Ambient Glow behind the bulb -->
    <path android:pathData="M54,70m-24,0a24,24 0,1 1,48 0a24,24 0,1 1,-48 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="70"
                android:gradientRadius="24"
                android:type="radial">
                <item
                    android:color="#B0FFE57F"
                    android:offset="0.0" />
                <item
                    android:color="#00FFE57F"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Cable -->
    <path
        android:pathData="M54,0 L54,36"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:strokeLineCap="round" />

    <!-- Upper Housing: Premium gold/champagne anodized holder with rounded top/bottom -->
    <!-- Bounds: X from 45 to 63 (width 18), Y from 36 to 54 (height 18) -->
    <path android:pathData="M45,40C45,37.8 46.8,36 49,36 L59,36C61.2,36 63,37.8 63,40 L63,50C63,52.2 61.2,54 59,54 L49,54C46.8,54 45,52.2 45,50 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="45"
                android:startY="36"
                android:endX="63"
                android:endY="54"
                android:type="linear">
                <item
                    android:color="#FFE8B0"
                    android:offset="0.0" />
                <item
                    android:color="#D4AF37"
                    android:offset="0.5" />
                <item
                    android:color="#AA7C11"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Tiny black connector spacer -->
    <path
        android:pathData="M51,54 L57,54 L57,56 L51,56 Z"
        android:fillColor="#222222" />

    <!-- Lower Bulb: Frosted Opal glass sphere -->
    <!-- Center: (54, 71), Radius: 15 (Diameter: 30) -->
    <path android:pathData="M54,71m-15,0a15,15 0,1 1,30 0a15,15 0,1 1,-30 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="71"
                android:gradientRadius="15"
                android:type="radial">
                <item
                    android:color="#FFFFFF"
                    android:offset="0.0" />
                <item
                    android:color="#FFF3CD"
                    android:offset="0.75" />
                <item
                    android:color="#FFE0B2"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle elegant reflection highlight on the bulb -->
    <path android:pathData="M49,63m-5,0a5,5 0,1 1,10 0a5,5 0,1 1,-5 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="49"
                android:centerY="63"
                android:gradientRadius="5"
                android:type="radial">
                <item
                    android:color="#70FFFFFF"
                    android:offset="0.0" />
                <item
                    android:color="#00FFFFFF"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
