    <path android:pathData="M49,30 L59,30 C61.8,30 64,32.2 64,35 L64,43 C64,45.8 61.8,48 59,48 L49,48 C46.2,48 44,45.8 44,43 L44,35 C44,32.2 46.2,30 49,30 Z">
