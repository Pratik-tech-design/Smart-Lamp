                android:startY="30"
                android:endX="64"
                android:endY="48"
                android:type="linear">
                <item
                    android:color="#6D482F"
                    android:offset="0.0" />
                <item
                    android:color="#4E311D"
                    android:offset="0.6" />
                <item
                    android:color="#3B2211"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Wood grain subtle vertical stripes -->
    <path
        android:pathData="M48,32 C47.5,37 48.5,41 48,46"
        android:strokeColor="#2F1B0C"
        android:strokeWidth="0.8" />
    <path
        android:pathData="M52,31 C51.5,36 52.5,41 52,47"
        android:strokeColor="#2F1B0C"
        android:strokeWidth="0.8" />
    <path
        android:pathData="M56,31 C55.5,36 56.5,41 56,47"
        android:strokeColor="#2F1B0C"
        android:strokeWidth="0.8" />
    <path
